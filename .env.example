# LLM: Hugging Face Inference / router (OpenAI-compatible).
# Create a token at https://huggingface.co/settings/tokens — never commit real tokens.
# API_KEY is accepted as an alias for HF_TOKEN (dashboard / hackathon compatibility).
HF_TOKEN=hf_YOUR_TOKEN_HERE
# API_KEY=hf_YOUR_TOKEN_HERE
API_BASE_URL=https://router.huggingface.co/v1
# Must be a model the router exposes for *chat* completions (not legacy completion-only ids).
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# HTTP 402 from router = HF Inference Providers billing/quota (not fixable in code).
# Fix: https://huggingface.co/settings/billing — or use local Ollama (see below).
# After first 402, stop calling HF and use fallback only (cleaner logs; optional):
# INFERENCE_SKIP_LLM_AFTER_402=0

# HARD task shortcut (debug only): after a propose with dynamic discounting, force next step to accept.
# Keep disabled for benchmark-quality runs so hard mode reflects genuine multi-round negotiation.
# INFERENCE_HARD_TWO_STEP=0

# Free local LLM (dev): install https://ollama.com then `ollama pull llama3.2`
# API_BASE_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=llama3.2
# HF_TOKEN=

# Docker / HF Space: image name for builds and openenv validate. inference.py does NOT use
# from_docker_image(); it talks to the env via HTTP (SMENegotiatorEnv) or in-process
# (OPENENV_IN_PROCESS=1 + InProcessSMENegotiatorBridge).
# LOCAL_IMAGE_NAME=openenv-sme-negotiator:latest

# Inference: optional — comma-separated difficulties, e.g. EASY,MEDIUM (omit for all three).
# TASK_FILTER=EASY,MEDIUM

# OpenEnv SME server (not the LLM) — only used when OPENENV_IN_PROCESS=0
OPENENV_BASE_URL=http://127.0.0.1:7860
# Set to 1 to run the simulator inside inference.py (no `uv run server` required)
OPENENV_IN_PROCESS=0
